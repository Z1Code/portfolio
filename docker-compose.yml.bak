services:
  web:
    build: .
    container_name: 7uanf-web
    restart: unless-stopped
    ports:
      - "127.0.0.1:3002:3000"
    mem_limit: 512m
    cpus: 1.0
    healthcheck:
      test: ["CMD", "wget", "--no-verbose", "--tries=1", "--spider", "http://localhost:3000/api/health"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 15s
    environment:
      - NODE_ENV=production
      - NEXT_TELEMETRY_DISABLED=1
